{
  "manifest_version": 3,
  "name": "__MSG_name__",
  "version": "2.3.0",
  "description": "__MSG_description__",
  "homepage_url": "https://github.com/PKxk8J/click-tab-uniq",
  "browser_specific_settings": {
    "gecko": {
      "id": "{e3e32590-2c56-405d-9f0f-9dc571a87d67}",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "menus",
    "notifications",
    "storage",
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "default_locale": "en",
  "options_ui": {
    "page": "options.html"
  }
}
